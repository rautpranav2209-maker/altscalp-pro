# AltScalp PRO — Environment Variables

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Your Razorpay Key ID (public key shown in Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# Your Razorpay Key Secret (NEVER expose to frontend or commit to git)
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Webhook secret configured in Razorpay Dashboard → Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Firebase ──────────────────────────────────────────────────────────────────
# Base64-encoded Firebase Admin SDK service account JSON
# Generate from Firebase Console → Project Settings → Service Accounts
# Encode: base64 -i service-account.json
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json_here

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the Express server (local dev only; Vercel ignores this)
PORT=3001

# Allowed CORS origin (your frontend URL)
ALLOWED_ORIGIN=https://altscalp-pro.vercel.app

# ── Notes ─────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in real values
# 2. NEVER commit .env to git (it is listed in .gitignore)
# 3. In Vercel: add each variable via Project Settings → Environment Variables
