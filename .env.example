# AltScalp PRO — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Firebase Admin SDK ──────────────────────────────────────────────────────
# Base64-encoded Firebase service account JSON.
# Generate at: Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT=<base64-encoded-service-account-json>

# ── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── CORS ────────────────────────────────────────────────────────────────────
# The frontend origin that is allowed to call the API
ALLOWED_ORIGIN=https://altscalp-pro.vercel.app

# ── WebSocket Server (optional — for standalone ws server deployment) ───────
# Port the WebSocket server listens on (default: 8080)
WS_PORT=8080
# Optional shared secret for simple WebSocket auth (sent as x-ws-secret header)
WS_SECRET=

# ── Frontend WebSocket URL ──────────────────────────────────────────────────
# Set window.ALTSCALP_WS_URL in index.html or inject via build process.
# Leave blank to use HTTP polling fallback.
# Example: wss://your-ws-server.railway.app
ALTSCALP_WS_URL=
